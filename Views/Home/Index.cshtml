@{
    ViewData["Title"] = "15-06";
}

<div class="container-fluid py-3">

    <!-- Tiêu đề -->

    <div class="mb-4">
        <textarea id="TieuDe" name="TieuDe" rows="3" class="bg-light form-control text-center"> Tờ trình xin chủ trương</textarea>
    </div>

    <!-- Số tờ trình -->

    <div class="row align-items-center g-2 mb-4">

        <div class="col-auto">
            <label class="form-label mb-0">Số:</label>
        </div>

        <div class="col-auto">
            <input id="SoToTrinh" name="SoToTrinh" value="/TTr-SXKD" class="form-control text-center" />
        </div>

        <div class="col-auto ms-4">
            <label class="form-label mb-0">Ngày:</label>
        </div>
        
        <div class="col-1">
            <input id="NgayToTrinh" name="NgayToTrinh" value="@DateTime.Now.Day" class="form-control text-center" />
        </div>

        <div class="col-auto">
            <label class="form-label mb-0">Tháng:</label>
        </div>

        <div class="col-1">
            <input id="ThangToTrinh" name="ThangToTrinh" value="@DateTime.Now.Month" class="form-control text-center" />
        </div>

        <div class="col-auto">
            <label class="form-label mb-0">Năm:</label>
        </div>

        <div class="col-1">
            <input id="NamToTrinh" name="NamToTrinh" value="@DateTime.Now.Year" class="form-control text-center" />
        </div>

    </div>

    <!-- Dự án -->

    <div class="row mb-3">

        <div class="col-md-3 text-md-end">
            <label class="form-label">Dự án:</label>
        </div>

        <div class="col-md-6">
            <input list="TenDuAn" id="DuAn" name="DuAn" onclick="this.select()" class="form-control" />
        </div>

        <datalist id="TenDuAn">
            <option value="Khu Công nghiệp và Dân cư Becamex - Bình Phước"></option>
            <option value="Khu Công nghiệp Becamex - Bình Phước"></option>
            <option value="Khu Tái định cư - Dân cư Ấp 1"></option>
            <option value="Khu Dân cư Ấp 4"></option>
            <option value="Khu Dân cư Ấp 4B"></option>
        </datalist>

    </div>

    <!-- Công trình -->

    <div class="row mb-3 text-md-end">

        <div class="col-md-3">
            <label class="form-label">Công trình:</label>
        </div>

        <div class="col-md-8">
            <input list="TenCongTrinh" id="CongTrinh" name="CongTrinh" onclick="this.select()" class="form-control" />
        </div>

        <datalist id="TenCongTrinh">
            <option value="Khu Công nghiệp và Dân cư Becamex - Bình Phước"></option>
            <option value="Khu Công nghiệp Becamex - Bình Phước"></option>
            <option value="Khu Công nghiệp - Khu B"></option>
            <option value="Khu Công nghiệp phía Bắc khu A (phía Bắc suối Cái)"></option>
            <option value="Khu Công nghiệp phía Nam khu A (phía Nam suối Cái)"></option>
            <option value="Khu Tái định cư - Dân cư Ấp 1"></option>
            <option value="Khu Dân cư Ấp 4"></option>
            <option value="Khu Dân cư Ấp 4B"></option>
        </datalist>

    </div>

    <!-- Hạng mục -->

    <div class="row mb-3 text-md-end">

        <div class="col-md-3">
            <label class="form-label">Hạng mục:</label>
        </div>

        <div class="col-md-8">
            <textarea id="HangMuc" name="HangMuc" rows="2" onclick="this.select()" class="form-control"></textarea>
        </div>
    </div>

    <!-- Địa điểm -->

    <div class="row mb-4 text-md-end">

        <div class="col-md-3">
            <label class="form-label">Địa điểm:</label>
        </div>

        <div class="col-md-6">
            <input id="DiaDiem" name="DiaDiem" value="Phường Chơn Thành, Thành phố Đồng Nai" class="form-control" />
        </div>

    </div>

    <!-- Quyết định lựa chọn đơn vị thi công -->
    <div class="fw-bold">
        I. Quyết định lựa chọn đơn vị thi công:<br />
        1. Căn cứ:
    </div>
    <div class="col-mb-4">
        <textarea id="CanCu" name="CanCu" rows="16" onclick="this.select()" class="form-control"></textarea>
    </div>
    <br />
    <div class="fw-bold">
        2. Nguyên nhân trình ký:
    </div>
    <div class="col-mb-4">
        <textarea id="NguyenNhanTrinhKy" name="NguyenNhanTrinhKy" rows="26" onclick="this.select()" class="form-control"></textarea>
    </div>

    <br />
    <!-- Đơn vị thực hiện -->

    <div class="card mb-4">

        <div class="card-header fw-bold">
            3. Đơn vị thực hiện (Bên B)
        </div>

        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-1">
                    <label class="form-label">NCC</label>
                </div>

                <div class="col-md-11">
                    <input id="NhaCungCap" name="NhaCungCap" class="form-control" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-1">
                    <label class="form-label">Địa chỉ</label>
                </div>

                <div class="col-md-11">
                    <input id="Diachi" name="Diachi" class="form-control" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-1">
                    <label class="form-label">SĐT</label>
                </div>
                <div class="col-md-4">
                    <input id="SoDienThoai" name="SoDienThoai" class="form-control" />
                </div>


                <div class="col-md-2 text-md-end">
                    <label class="form-label">Email</label>
                </div>
                <div class="col-md-5">
                    <input id="Email" name="Email" value="@@gmail.com" class="form-control" />
                </div>

            </div>

            <div class="row mb-3">

                <div class="col-md-1">
                    <label class="form-label">STK</label>
                </div>

                <div class="col-md-11">
                    <input id="STK1" name="STK1" class="form-control mb-2" />
                    <input id="STK2" name="STK2" class="form-control" />
                </div>

            </div>

            <div class="row mb-3">

                <div class="col-md-1">
                    <label class="form-label">MST</label>
                </div>

                <div class="col-md-4">
                    <input id="MST" name="MST" class="form-control fw-bold" oninput="formatMST(this)" />
                </div>

            </div>

            <div class="row">

                <div class="col-md-1">
                    <label class="form-label">Đại diện</label>
                </div>
                <div class="col-md-5">
                    <input id="DaiDien" name="DaiDien" value="Ông " class="form-control" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Chức vụ</label>
                    <select class="form-select">
                        <option>Tổng Giám đốc</option>
                        <option>Phó Tổng Giám đốc</option>
                        <option>Giám đốc</option>
                        <option>Phó Giám đốc</option>
                    </select>
                </div>

            </div>

        </div>

    </div>

    <!-- Giá trị hợp đồng -->

    <div class="card">

        <div class="card-header fw-bold">Giá trị hợp đồng</div>

        <div class="card-body">
            <label class="form-label">Giá trị hợp đồng</label>
            <input id="Giatri" class="form-control" />
        </div>

    </div>

</div>

<script>
    function formatMST(input) {
                               let value = input.value.replace(/\s/g, '');
                               input.value = value.split('').join(' ');
                               }
</script>


<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>
